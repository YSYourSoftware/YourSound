  SendMessage $hCtl_Paths_Label2 ${WM_SETFONT} $hCtl_Paths_Font1 0
  
  ; === LIBLocationInput_Txt (type: Text) ===
  ${NSD_CreateText} 7u 90u 262u 13u "C:\Program Files\YourSoftware\YourSound\Libraries"
