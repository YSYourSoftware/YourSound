; onClick handler for DirRequest Button $hCtl_Paths_LIBLocationInput_Btn
Function fnc_hCtl_Paths_LIBLocationInput_Click
	Pop $R0
	${If} $R0 == $hCtl_Paths_LIBLocationInput_Btn
		${NSD_GetText} $hCtl_Paths_LIBLocationInput_Txt $R0
		nsDialogs::SelectFolderDialog /NOUNLOAD "" "$R0"
		Pop $R0
		${If} "$R0" != "error"
			${NSD_SetText} $hCtl_Paths_LIBLocationInput_Txt "$R0"
		${EndIf}
	${EndIf}
FunctionEnd

