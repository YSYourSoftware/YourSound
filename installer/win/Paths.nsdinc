; dialog create function
Function fnc_Paths_Create
  
  ; custom font definitions
  CreateFont $hCtl_Paths_Font1 "Fira Sans" "8.25" "400"
  CreateFont $hCtl_Paths_Font2 "Fira Sans" "20" "700"
  
  ; === Paths (type: Dialog) ===
  nsDialogs::Create 1018
  Pop $hCtl_Paths
  ${If} $hCtl_Paths == error
    Abort
  ${EndIf}
  SendMessage $hCtl_Paths ${WM_SETFONT} $hCtl_Paths_Font1 0
  !insertmacro MUI_HEADER_TEXT "Installing YourSound..." "Installation Directories"
  
  ; === HLine1 (type: HLine) ===
  ${NSD_CreateHLine} 0u 20u 296u 1u ""
