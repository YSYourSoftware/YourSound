  ; === VST3LocationInput_Btn (type: Button) ===
  ${NSD_CreateButton} 270u 64u 20u 8u "..."
  Pop $hCtl_Paths_VST3LocationInput_Btn
  SendMessage $hCtl_Paths_VST3LocationInput_Btn ${WM_SETFONT} $hCtl_Paths_Font1 0
  ${NSD_OnClick} $hCtl_Paths_VST3LocationInput_Btn fnc_hCtl_Paths_VST3LocationInput_Click
  
  ; === EXELocationInput_Txt (type: Text) ===
  ${NSD_CreateText} 7u 33u 262u 13u "C:\Program Files\YourSoftware\YourSound"
  Pop $hCtl_Paths_EXELocationInput_Txt
